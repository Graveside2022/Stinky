# Webhook Service Configuration
WEBHOOK_PORT=8002
WEBHOOK_HOST=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/webhook.log

# Service Paths
MAIN_SCRIPT=/home/pi/stinky/gps_kismet_wigle.sh
KISMET_OPS_PATH=/home/pi/kismet_ops/
KISMET_LOG_PATH=/var/log/kismet/kismet.log

# PID Files
PID_FILE=/tmp/kismet_pids.txt
SCRIPT_PID_FILE=/tmp/kismet_script.pid
WIGLETOTAK_PID_FILE=/home/pi/tmp/wigletotak.specific.pid

# Kismet Configuration
KISMET_API_URL=http://10.42.0.1:2501
KISMET_AUTH_USER=admin
KISMET_AUTH_PASS=admin

# CORS Configuration
CORS_ORIGINS=http://localhost:8092,http://localhost:8000

# Process Management
SCRIPT_START_TIMEOUT=30000
KISMET_RETRY_COUNT=12
KISMET_RETRY_INTERVAL=5000
WIGLE_RETRY_COUNT=5
WIGLE_RETRY_INTERVAL=10000

# WebSocket Configuration
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100